# 视频选择 (1-6)
# 1: dual_scroll  (双滚动)
# 2: diagonal     (斜向运动)
# 3: circular     (圆周运动)
# 4: spiral       (螺旋运动)
# 5: pulsing      (缩放脉冲)
# 6: figure_eight (8字形运动)
VIDEO_CHOICE=2

# 卷积核大小 (2-6)
# 2: 轻度模糊
# 3: 中度模糊
# 4: 较强模糊
# 5: 强模糊
# 6: 处理所有尺寸 (2,3,4,5,6)
CONVOLUTION_SIZE=3

# 图像放大倍数（在时间维度运动模糊前，将每帧图像放大此倍数）
# 建议：视频尺寸≤720p时使用4，≥1080p时使用2
SCALE_FACTOR=2

# 最大池化核大小（用于边缘检测后还原图像大小）
POOL_SIZE=2