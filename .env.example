# 视频选择 (1-6)
# 1: dual_scroll  (双滚动)
# 2: diagonal     (斜向运动)
# 3: circular     (圆周运动)
# 4: spiral       (螺旋运动)
# 5: pulsing      (缩放脉冲)
# 6: figure_eight (8字形运动)
VIDEO_CHOICE=2

# 卷积核大小 (2-6)
# 2: 轻度模糊
# 3: 中度模糊
# 4: 较强模糊
# 5: 强模糊
# 6: 处理所有尺寸 (2,3,4,5,6)
CONVOLUTION_SIZE=3

# 图像放大倍数（在时间维度运动模糊前，将每帧图像放大此倍数）
SCALE_FACTOR=4

# 最大池化核大小（用于边缘检测后还原图像大小）
POOL_SIZE=4

# 边缘检测方法: prewitt（3D卷积）或 fft（3D频域分析）
METHOD=prewitt

# FFT 方法的空间分块大小（仅 METHOD=fft 时生效，默认 512）
FFT_TILE_SIZE=512